# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# Public-facing base URL (used to build QR code links)
APP_URL=http://localhost:3000

# ── Session ───────────────────────────────────────────────────────────────────
# REQUIRED in production: generate with `node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"`
SESSION_SECRET=change-this-to-a-long-random-string-before-production

# ── Admin login ───────────────────────────────────────────────────────────────
# Change these before going live
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Supports Gmail (use an App Password), SendGrid, Mailgun, etc.
# Leave blank to queue emails instead of sending (admin can review in AI Agent tab)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@classicproductions.com

# ── Twilio SMS ────────────────────────────────────────────────────────────────
# Leave blank to queue SMS instead of sending
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── Claude AI (Anthropic) ─────────────────────────────────────────────────────
# Powers personalised re-engagement message copy.
# Leave blank to use default template messages instead.
ANTHROPIC_API_KEY=
